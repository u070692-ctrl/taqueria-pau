rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() { return hasRole('admin'); }
    function isWorker() { return hasRole('worker'); }
    function isCustomer() { return hasRole('customer'); }

    // Clientes
    match /clientes/{clienteId} {
      allow read: if isAdmin() || isWorker();
      allow create: if isSignedIn(); // Customers or workers/admins can create
      allow update, delete: if isAdmin();
    }

    // Productos
    match /productos/{productoId} {
      allow read: if true; // Everyone can see the menu
      allow write: if isAdmin();
    }

    // Pedidos
    match /pedidos/{pedidoId} {
      allow read: if isAdmin() || isWorker() || (isCustomer() && resource.data.clienteId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || isWorker();
      allow delete: if isAdmin();
    }

    // Usuarios (Roles & Profiles)
    match /usuarios/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin') || hasRole('worker'));
      allow create: if isSignedIn() && request.auth.uid == userId; 
      allow update: if hasRole('admin') || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if hasRole('admin');
    }
  }
}
